# Required in every deployed environment
DATABASE_URL="postgresql://quizforge:quizforge@localhost:5432/quizforge?schema=public"
JWT_SECRET="replace-with-at-least-32-random-characters"
APP_URL="http://localhost:3000"

# AI provider: keep server-side only. Never prefix with NEXT_PUBLIC_.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-oss-120b:free"
OPENROUTER_FALLBACK_MODEL="meta-llama/llama-3.3-70b-instruct"
OPENROUTER_EVALUATION_MODEL="google/gemma-4-31b-it"
OPENROUTER_TIMEOUT_MS="55000"
OPENROUTER_EVALUATION_TIMEOUT_MS="12000"

# Transactional email. In development, leave the key empty until EMAIL_FROM uses
# a verified Resend domain. Local verification and reset URLs are logged, and
# signup returns a development verification link when provider delivery is off.
# In production, verify a domain in Resend and use its exact domain or subdomain.
RESEND_API_KEY=""
EMAIL_FROM="QuizForge <no-reply@example.com>"

# Optional one-time admin bootstrap values used only by npm run db:seed.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Optional deployment metadata sent to OpenRouter.
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_NAME="QuizForge"
