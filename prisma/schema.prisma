generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ADAPTIVE
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AIRequestStatus {
  SUCCESS
  FAILED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum TeamInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum TeamChallengeStatus {
  OPEN
  CLOSED
}

enum QuizCollaboratorRole {
  MANAGER
  EDITOR
  VIEWER
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  name              String
  passwordHash      String
  timezone          String              @default("UTC")
  role              Role                @default(USER)
  status            UserStatus          @default(ACTIVE)
  emailVerifiedAt   DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  sessions          Session[]
  verificationTokens VerificationToken[]
  quizzes           Quiz[]              @relation("QuizAuthor")
  attempts          QuizAttempt[]
  aiRequests        AIRequest[]
  activityLogs      ActivityLog[]
  activityDays      UserActivityDay[]
  progress          UserProgress?
  ownedTeams        Team[]              @relation("TeamOwner")
  teamMemberships   TeamMember[]
  teamInvitations   TeamInvitation[]    @relation("InvitationRecipient")
  sentInvitations   TeamInvitation[]    @relation("InvitationSender")
  createdChallenges TeamChallenge[]     @relation("ChallengeCreator")
  quizCollaborations QuizCollaborator[]

  @@index([createdAt])
  @@index([status])
}

model Session {
  id               String   @id @default(cuid())
  refreshTokenHash String   @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model VerificationToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  quizzes     Quiz[]
}

model Quiz {
  id          String       @id @default(cuid())
  title       String
  description String?
  topic       String
  difficulty  Difficulty   @default(ADAPTIVE)
  status      QuizStatus   @default(DRAFT)
  isAIGenerated Boolean    @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  authorId    String?
  author      User?        @relation("QuizAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  teamId      String?
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  questions   Question[]
  attempts    QuizAttempt[]
  challenges  TeamChallenge[]
  collaborators QuizCollaborator[]
  invitations TeamInvitation[]

  @@index([status, createdAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([teamId])
}

model Question {
  id          String   @id @default(cuid())
  prompt      String
  explanation String
  position    Int
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options     Option[]
  answers     AttemptAnswer[]

  @@unique([quizId, position])
}

model Option {
  id         String   @id @default(cuid())
  label      String
  isCorrect  Boolean  @default(false)
  position   Int
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    AttemptAnswer[]

  @@unique([questionId, position])
}

model QuizAttempt {
  id          String          @id @default(cuid())
  score       Int
  total       Int
  durationSeconds Int         @default(0)
  completedAt DateTime        @default(now())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId      String
  quiz        Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers     AttemptAnswer[]
  teamChallengeId String?
  teamChallenge TeamChallenge? @relation(fields: [teamChallengeId], references: [id], onDelete: SetNull)

  @@index([userId, completedAt])
  @@index([quizId, completedAt])
  @@index([teamChallengeId, completedAt])
}

model AttemptAnswer {
  id         String      @id @default(cuid())
  isCorrect  Boolean
  attemptId  String
  attempt    QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  optionId   String
  option     Option      @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([attemptId, questionId])
}

model AIRequest {
  id           String          @id @default(cuid())
  feature      String
  model        String
  status       AIRequestStatus
  latencyMs    Int
  tokenCount   Int?
  errorCode    String?
  createdAt    DateTime        @default(now())
  userId       String?
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
}

model UserActivityDay {
  id          String   @id @default(cuid())
  dayKey      String
  timezone    String
  completedAt DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
  @@index([dayKey])
}

model UserProgress {
  userId               String   @id
  quizzesCompleted     Int      @default(0)
  totalQuestions       Int      @default(0)
  correctAnswers       Int      @default(0)
  incorrectAnswers     Int      @default(0)
  totalDurationSeconds Int      @default(0)
  bestScorePercent     Int      @default(0)
  currentStreak        Int      @default(0)
  longestStreak        Int      @default(0)
  lastActiveDay        String?
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([correctAnswers, quizzesCompleted])
}

model Team {
  id          String           @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  ownerId     String
  owner       User             @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  invitations TeamInvitation[]
  challenges  TeamChallenge[]
  quizzes      Quiz[]

  @@index([ownerId])
}

model TeamMember {
  id       String   @id @default(cuid())
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())
  teamId   String
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model TeamInvitation {
  id          String               @id @default(cuid())
  email       String
  tokenHash   String               @unique
  status      TeamInvitationStatus @default(PENDING)
  role        TeamRole             @default(MEMBER)
  quizRole    QuizCollaboratorRole?
  expiresAt   DateTime
  createdAt   DateTime             @default(now())
  respondedAt DateTime?
  acceptedAt  DateTime?
  teamId      String
  team        Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  quizId      String?
  quiz        Quiz?                @relation(fields: [quizId], references: [id], onDelete: Cascade)
  invitedUserId String?
  invitedUser User?                @relation("InvitationRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User                 @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([teamId, email, status])
  @@index([invitedUserId, status])
  @@index([expiresAt])
}

model TeamChallenge {
  id          String              @id @default(cuid())
  title       String
  status      TeamChallengeStatus @default(OPEN)
  deadline    DateTime?
  createdAt   DateTime            @default(now())
  teamId      String
  team        Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  quizId      String
  quiz        Quiz                @relation(fields: [quizId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User                @relation("ChallengeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  attempts    QuizAttempt[]

  @@index([teamId, createdAt])
  @@index([quizId])
}

model QuizCollaborator {
  id        String               @id @default(cuid())
  role      QuizCollaboratorRole @default(VIEWER)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  quizId    String
  quiz      Quiz                 @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quizId, userId])
  @@index([userId])
}
